# Claude API キー(未設定の場合、自然文解析はルールベースにフォールバック)
ANTHROPIC_API_KEY=

# 使用モデル(省略時: claude-sonnet-5)
# CHOSEI_AGENT_MODEL=claude-sonnet-5

# SQLite データディレクトリ(省略時: ./data)
# CHOSEI_DATA_DIR=./data

# 合言葉(アクセスキー)。設定するとイベント作成・AI 解析に必須になる。本番では設定を推奨
# CHOSEI_ACCESS_KEY=

# Claude 呼び出しの 1 日上限(省略時: 200)。超過後はルールベースに自動縮退
# CHOSEI_AGENT_DAILY_LIMIT=200
